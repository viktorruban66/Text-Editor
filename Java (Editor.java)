import java.io.*;
import java.util.*;
import java.util.regex.*;

public class Editor {
    private String filename;
    private List<String> lines;
    private boolean modified;

    public Editor(String filename) {
        this.filename = filename;
        this.lines = new ArrayList<>();
        this.modified = false;
        if (filename != null && !filename.isEmpty()) {
            try (BufferedReader br = new BufferedReader(new FileReader(filename))) {
                String line;
                while ((line = br.readLine()) != null) {
                    lines.add(line);
                }
            } catch (IOException e) {}
        }
        if (lines.isEmpty()) lines.add("");
    }

    private void display() {
        clearScreen();
        System.out.println("--- " + (filename == null ? "untitled" : filename) + " --- Lines: " + lines.size());
        for (int i = 0; i < lines.size(); i++) {
            System.out.printf("%3d %s%n", i+1, lines.get(i));
        }
        if (modified) System.out.println("[!] NOT SAVED");
    }

    private void clearScreen() {
        try {
            if (System.getProperty("os.name").contains("Windows"))
                new ProcessBuilder("cmd", "/c", "cls").inheritIO().start().waitFor();
            else
                System.out.print("\033[2J\033[1;1H");
        } catch (Exception e) {}
    }

    private void editLine(int num) throws IOException {
        if (num < 1 || num > lines.size()) {
            System.out.println("Invalid line number");
            return;
        }
        int idx = num-1;
        System.out.println(num + "> " + lines.get(idx));
        System.out.print("new content: ");
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        String newLine = br.readLine();
        if (!lines.get(idx).equals(newLine)) {
            lines.set(idx, newLine);
            modified = true;
        }
    }

    private void insertLine(int pos) throws IOException {
        if (pos < 0 || pos > lines.size()) {
            System.out.println("Invalid position");
            return;
        }
        System.out.print("insert text: ");
        BufferedReader br = new BufferedReader(new InputStreamReader(System.in));
        String newLine = br.readLine();
        lines.add(pos, newLine);
        modified = true;
    }

    private void deleteLine(int num) {
        if (num < 1 || num > lines.size()) {
            System.out.println("Invalid line number");
            return;
        }
        lines.remove(num-1);
        if (lines.isEmpty()) lines.add("");
        modified = true;
    }

    private boolean save(String fname) {
        String outName = (fname == null || fname.isEmpty()) ? filename : fname;
        if (outName == null || outName.isEmpty()) {
            System.out.println("No filename. Use :w <filename>");
            return false;
        }
        try (PrintWriter pw = new PrintWriter(new FileWriter(outName))) {
            for (int i = 0; i < lines.size(); i++) {
                pw.println(lines.get(i));
            }
            filename = outName;
            modified = false;
            System.out.println("Saved.");
            return true;
        } catch (IOException e) {
            System.out.println("Save error: " + e.getMessage());
            return false;
        }
    }

    private void search(String pattern) {
        try {
            Pattern p = Pattern.compile(pattern);
            boolean found = false;
            for (int i = 0; i < lines.size(); i++) {
                Matcher m = p.matcher(lines.get(i));
                if (m.find()) {
                    System.out.printf("%3d %s%n", i+1, lines.get(i));
                    found = true;
                }
            }
            if (!found) System.out.println("Not found");
        } catch (PatternSyntaxException e) {
            System.out.println("Regex error: " + e.getMessage());
        }
    }

    private void replace(String pattern, String repl, boolean globalFlag) {
        try {
            Pattern p = Pattern.compile(pattern);
            boolean changed = false;
            for (int i = 0; i < lines.size(); i++) {
                String line = lines.get(i);
                String newLine = globalFlag ? p.matcher(line).replaceAll(repl) : p.matcher(line).replaceFirst(repl);
                if (!newLine.equals(line)) {
                    lines.set(i, newLine);
                    changed = true;
                    if (!globalFlag) break;
                }
            }
            if (changed) {
                modified = true;
                System.out.println("Replaced.");
            } else {
                System.out.println("Pattern not found.");
            }
        } catch (PatternSyntaxException e) {
            System.out.println("Regex error: " + e.getMessage());
        }
    }

    public void run() throws IOException {
        BufferedReader console = new BufferedReader(new InputStreamReader(System.in));
        display();
        while (true) {
            System.out.print("> ");
            String cmd = console.readLine();
            if (cmd == null) break;
            cmd = cmd.trim();
            if (cmd.isEmpty()) {
                display();
                continue;
            }
            if (cmd.charAt(0) == ':') {
                String rest = cmd.substring(1);
                if (rest.equals("help")) {
                    System.out.println("Commands: :help, :list, :e <num>, :i <num>, :d <num>, :w [file], :q, :wq, :s/old/new/g, :/pattern");
                } else if (rest.equals("list") || rest.equals("p")) {
                    display();
                } else if (rest.equals("q")) {
                    if (modified) {
                        System.out.print("Changes not saved. Quit anyway? (y/N) ");
                        String ans = console.readLine();
                        if (!ans.equalsIgnoreCase("y")) continue;
                    }
                    System.out.println("Goodbye.");
                    break;
                } else if (rest.equals("wq")) {
                    if (save(null)) break;
                } else if (rest.startsWith("w ")) {
                    save(rest.substring(2));
                } else if (rest.equals("w")) {
                    save(null);
                } else if (rest.startsWith("e ")) {
                    try {
                        int num = Integer.parseInt(rest.substring(2));
                        editLine(num);
                    } catch (NumberFormatException e) { System.out.println("Need a number"); }
                } else if (rest.startsWith("i ")) {
                    try {
                        int pos = Integer.parseInt(rest.substring(2));
                        insertLine(pos);
                    } catch (NumberFormatException e) { System.out.println("Need a number"); }
                } else if (rest.startsWith("d ")) {
                    try {
                        int num = Integer.parseInt(rest.substring(2));
                        deleteLine(num);
                    } catch (NumberFormatException e) { System.out.println("Need a number"); }
                } else if (rest.startsWith("/")) {
                    search(rest.substring(1));
                } else if (rest.startsWith("s/")) {
                    Pattern p = Pattern.compile("^s/(.*?)/(.*?)/(g?)$");
                    Matcher m = p.matcher(rest);
                    if (m.matches()) {
                        replace(m.group(1), m.group(2), m.group(3).equals("g"));
                    } else {
                        System.out.println("Invalid syntax. Use :s/old/new/g");
                    }
                } else {
                    System.out.println("Unknown command. :help");
                }
            } else {
                try {
                    int num = Integer.parseInt(cmd);
                    editLine(num);
                } catch (NumberFormatException e) {
                    System.out.println("Unknown command. Type :help");
                }
            }
        }
    }

    public static void main(String[] args) throws IOException {
        String filename = args.length > 0 ? args[0] : null;
        Editor editor = new Editor(filename);
        editor.run();
    }
}
